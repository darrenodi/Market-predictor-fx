# ─── Supabase (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Anthropic / Claude AI (required) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Telegram (required for bot) ─────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFghijklmnopqrstuvwxyz
# Get group chat ID by adding @userinfobot to your group
TELEGRAM_GROUP_ID=-1001234567890

# ─── Security ─────────────────────────────────────────────────────────────────
# Random secret used to authenticate cron job calls (generate with: openssl rand -hex 32)
CRON_SECRET=your-random-cron-secret-here
# Secret for admin API calls (change meme coin etc.)
ADMIN_SECRET=your-random-admin-secret-here

# ─── Optional: NewsAPI ────────────────────────────────────────────────────────
# Free tier: 100 requests/day — https://newsapi.org
# If omitted, the system uses free RSS feeds instead
NEWS_API_KEY=

# ─── Notes ───────────────────────────────────────────────────────────────────
# Prices:  CoinGecko free API (no key needed)
# Gold:    Pax Gold (PAXG) via CoinGecko — no key needed
# News:    RSS feeds from CoinTelegraph, CoinDesk, Decrypt (no key needed)
# Crons:   Vercel Pro required for intervals < 1 day.
#          On Hobby plan, use cron-job.org (free) to call the cron endpoints.
